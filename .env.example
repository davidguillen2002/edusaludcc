# ──────────────────────────────────────────────────────────────────
# EduSaludCC — example environment variables
# Copy this file to `.env.local` for local development and set the
# same keys in Vercel → Project → Settings → Environment Variables
# for production.
# ──────────────────────────────────────────────────────────────────

# Public URL of the deployed site (used by sitemap + robots + OG).
# Local dev can omit this; production must set it.
NEXT_PUBLIC_SITE_URL=https://www.edusaludcc.com

# Resend API key — required to send contact form emails.
# Sign up free at https://resend.com and create an API key.
# Without this key the form runs but emails are skipped (logged only).
RESEND_API_KEY=

# Destination inbox for contact form submissions.
# Defaults to the email defined in lib/site.ts.
CONTACT_TO_EMAIL=edusaludcc@outlook.com

# Verified sender. Use Resend's onboarding address for free testing,
# or a domain you've verified at resend.com/domains.
# Format: "Display Name <address@yourdomain.com>"
CONTACT_FROM_EMAIL=EduSaludCC <onboarding@resend.dev>
